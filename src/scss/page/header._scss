$header: 5;
.header {
  top: 0;
  left: 0;
  width: 100%;
  z-index: 110;
  // box-shadow: 0 0 50px rgba(0, 0, 0, 0.08);
  transition: background-color var(--transition);

  @extend %header !optional;

  @if ($header == 1 or $header == 3) {
    position: absolute;
    transition: box-shadow var(--transition);

    @media ($header-min) {
      transform: translateY(0);
    }
    @media ($header-max) {
      position: fixed;
    }
  }
  @if ($header == 2 or $header == 4 or $header == 5) {
    position: fixed;
    // box-shadow: var(--box-shadow-big);

    // @media ($header-min) {
    //   transform: translateY(0);
    // }
  }
  @if ($header == 5) {
    background-color: var(--primary-c);

    &--transparent {
      background-color: rgba(255, 255, 255, 0);

      @extend %header-transparent !optional;
    }
    @media ($header-min) {
      &:hover {
        background-color: var(--header-hover);
      }
      &--transparent:hover {
        background-color: rgba(255, 255, 255, 0.1);
      }
    }

    // & + * {
    //   padding-top: var(--header-h);
    // }
  }
  @if ($header == 2 or $header == 5) {
    @media ($header-max) {
      &::before {
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        content: "";
        display: block;
        position: absolute;
        border-top: 1px solid change-color($color: $white, $alpha: 0.5);
        border-bottom: 1px solid change-color($color: $white, $alpha: 0.5);
        background-color: var(--primary-c);
      }
      &::after {
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        opacity: 0;
        z-index: -1;
        content: "";
        display: block;
        position: fixed;
        visibility: hidden;
        transition:
          opacity 0.2s,
          visibility 0.2s;
        backdrop-filter: blur(5px);
        background-color: change-color($color: $grey-100, $alpha: 0.5);
      }
      &%menu-opened::after {
        opacity: 1;
        visibility: visible;
      }
    }
  }

  %scrolled & {
    transition:
      transform var(--transition),
      box-shadow var(--transition),
      background-color var(--transition);

    @media ($header-min) {
      @if ($header == 5) {
        box-shadow: 0 1px 0 rgba(0, 0, 0, 0.1);

        &%header-transparent {
          background-color: var(--primary-c);
        }
        &:hover {
          background-color: change-color($color: $primary-color, $lightness: 47%);
        }
      }
    }
  }

  @if ($header == 1 or $header == 3) {
    %scrolled & {
      @media ($header-min) {
        transform: translateY(-$header-scroll-height);
      }
    }
  }
  @if ($header == 2 or $header == 4 or $header == 5) {
    %hidden & {
      transform: translateY(calc(var(--header-h) * -1));

      @media ($header-min) {
        box-shadow: 0 0 30px rgba(0, 0, 0, 0);
      }
      @media ($header-max) {
        &%menu-opened {
          transform: none;
        }
      }
    }
  }
  &._menu-opened {
    @extend %menu-opened !optional;
  }
  &__wrapper {
    @extend %header-wrapper !optional;

    @if ($header == 2) {
      height: var(--header-h);
      display: flex;
      align-items: center;
      justify-content: space-between;

      @media ($header-max) {
        position: relative;
      }
    }
  }
  &__mobile {
    @if ($header == 1 or $header == 3 or $header == 4) {
      top: 0;
      left: 0;
      width: 100%;
      z-index: 10;
      position: fixed;
      // box-shadow: 0 0 30px rgba(0, 0, 0, 0.08);
      background-color: var(--primary-c);

      @media ($header-min) {
        display: none;
      }

      %scrolled & {
        box-shadow: 0 0 30px rgba(0, 0, 0, 0.08);
        transition:
          box-shadow var(--transition),
          transform var(--transition);
      }
    }
    @if ($header == 4 or $header == 5) {
      @media ($mobile-max) {
        %search-form {
          position: static;
        }
        %search-form-label {
          left: 0;
          right: 0;
          bottom: 0;
          opacity: 0;
          position: absolute;
          transform: translateY(100%) scaleY(0.5);
          visibility: hidden;
          transition:
            opacity 0.3s,
            visibility 0.3s,
            transform 0.3s;
          transform-origin: center top;
        }
        %search-form._opened %search-form-label {
          opacity: 1;
          transform: translateY(100%);
          visibility: visible;
        }
        %search-form-input {
          height: 50px;
          border-radius: 0;
        }
        %search-form-button {
          width: 30px;
          height: 30px;
          position: relative;

          svg {
            width: 62%;
            height: 62%;
          }
        }
        %search-form-button-close {
          display: block;
          position: absolute;
        }
      }
    }
    @if ($header == 5) {
      @media ($header-min) {
        display: none;
      }
    }

    @extend %header-mobile !optional;
  }
  &__mobile-inner {
    display: flex;
    // padding: 0 $container-mobile;
    min-height: var(--header-h);
    justify-content: space-between;

    @media ($header-min) {
      align-items: center;
    }
    @media ($header-max) {
      position: relative;
    }
  }
  &__mobile-item {
    flex: 0 1 auto;
    display: flex;
    align-items: center;

    &:nth-child(1) {
      @media ($header-max) {
        padding-right: var(--container-p);
      }
      @media ($mobile-max) {
        border-right: 1px solid change-color($color: $white, $alpha: 0.5);
      }
    }
    &:nth-child(3) {
      @media ($header-max) {
        padding-left: var(--container-p);
      }
      @media ($mobile-max) {
        border-left: 1px solid change-color($color: $white, $alpha: 0.5);
      }
    }

    // &:nth-child(1) {
    //   // flex-grow: 0.8;
    //   flex-shrink: 0;
    //   margin-right: 1.5rem;
    // }
    // &:nth-child(2) {
    //   // margin: 0 1.5rem;
    //   // flex-grow: 1;
    //   // text-align: right;
    //   margin-left: auto;
    //   margin-right: 1rem;
    // }
  }
  &__item {
    @media ($header-max) {
      @if ($header == 1) {
        &:nth-child(1) {
          order: 2;
        }
        &:nth-child(2) {
          order: 3;
        }
        &:nth-child(3) {
          order: 1;
        }
      }
      @if ($header == 2) {
        %header-wrapper > & + & {
          margin-left: 10px;
        }
        %header-navigation & {
          &:nth-child(1) {
            order: 3;
            margin-top: 30px;
          }
          &:nth-child(2) {
            order: 1;
          }
          &:nth-child(3) {
            order: 2;
            margin-top: 20px;
          }
        }
      }
      @if ($header == 3 or $header == 4) {
        &:nth-child(1) {
          order: 2;
        }
        &:nth-child(2) {
          order: 1;
        }
      }
      @if ($header == 5) {
        flex-grow: 1;
      }
    }
    &_logo {
      flex-shrink: 0;

      @media ($header-min) {
        transform: translateY(0);
        transition: transform 0.2s;
        margin-right: 1.4825rem;

        @if ($header == 2) {
          margin-left: 52px;
          margin-right: 52px;

          // %scrolled & {
          //   transform: translateY(calc(($header-middle-height + 5px) / 2));
          // }
        }
      }
    }
  }
  &__navigation {
    display: flex;
    flex-direction: column;

    @extend %header-navigation !optional;

    @media ($header-min) {
      flex-grow: 0.36;
    }
    @media ($header-max) {
      top: var(--header-h);
      right: 0;
      width: 400px;
      bottom: 0;
      // opacity: 0;
      padding: calc(var(--container-p) - 10px) var(--container-p) var(--container-p);
      position: fixed;
      transform: translateX(100%);
      overflow-y: auto;
      overflow-x: hidden;
      visibility: hidden;
      // box-shadow: inset 0 30px 30px -30px rgba(0, 0, 0, 0.08), 30px 0 30px -30px rgba(0, 0, 0, 0.08);
      box-shadow: var(--box-shadow-big);
      transition:
        opacity var(--transition),
        visibility var(--transition),
        transform var(--transition);
      background-color: var(--primary-c);
      @include small-scrollbar;

      %menu-opened & {
        right: 0;
        // opacity: 1;
        transform: translateX(0);
        visibility: visible;
      }

      @if ($header == 2) {
        & > *:nth-child(1) {
          order: 1;
        }
      }
    }
    @media ($header-max) and ($tablet-min) {
      border-left: 1px solid change-color($color: $white, $alpha: 0.5);
    }
    @media ($mobile-max) {
      width: 100%;
      padding-top: 30px;
      // width: calc(100% - 40px - $container-mobile * 2);
    }
  }
  &__collapse-button {
    $header-collapse-color-01: var(--white);
    $header-collapse-color-02: var(--primary-c);

    top: 0;
    right: 0;
    width: 50px;
    color: inherit;
    height: 100%;
    border: none;
    padding: 0;
    z-index: 105;
    position: absolute;
    // transform: translate(0, 2px) rotate(0);
    transition:
      color 0.2s,
      background-color 0.2s;
    background-color: transparent;

    @extend %header-collapse-button !optional;

    svg {
      width: 0.6875em;
      height: 0.6875em;
      transform: translate(0, -3px) rotate(-180deg);
      // transition: transform 0.6s cubic-bezier(0.58, -0.37, 0.43, 1.49);
      transition: transform 0.3s cubic-bezier(0.5, 0.5, 0.5, 1.33);
      transform-origin: 50% 80%;
    }
    // %hover-to-open-hover > * > &,
    %hover-to-open-opened > * > & {
      svg {
        transform: scaleY(1);
      }
    }

    @media ($header-min) {
      %catalog-list-item-hover > * > &:hover {
        color: var(--white);
        background-color: var(--primary-c);
      }
      %header-top-link + &,
      %header-bottom-link + & {
        top: auto;
        width: auto;
        height: auto;
        position: relative;
        margin-left: 6px;

        svg {
          // width: 0.857em;
          // height: 0.857em;
          width: 0.6em;
          height: 0.6em;
          display: block;
          // transform: rotate(90deg);
        }
        %hover-to-open-hover &,
        %hover-to-open-opened & {
          svg {
            // transform: rotate(180deg);
            transform: translate(0, -1px) rotate(0);
          }
        }
      }
      %header-top-link[href]:hover + &,
      %header-bottom-link[href]:hover + & {
        color: var(--white);

        // %hover-to-open-hover &,
        // %hover-to-open-opened & {
        //   svg {
        //     transform: rotate(180deg) translateY(2px);
        //   }
        // }
      }
      %catalog-grid & {
        display: none;
      }
    }
    @media ($header-max) {
      &::before {
        top: 50%;
        left: 50%;
        width: 30px;
        height: 30px;
        // content: "";
        display: block;
        position: absolute;
        transform: translate(-50%, -50%);
        border-radius: 50%;
        transition: background-color 0.2s;
        background-color: var(--grey-50);
      }
      svg {
        width: 12px;
        height: 12px;
        // transform: rotate(90deg);
        // transform: scaleY(-1);
      }
      %hover-to-open-opened > * > & {
        &::before {
          background-color: var(--primary-c);
        }
        // svg {
        //   // color: var(--white);
        //   // transform: rotate(180deg);
        //   transform: scaleY(1);
        // }
      }
    }
  }
  // & + * {
  //   margin-top: 3.75rem;

  //   @media ($desktop-max) and ($tablet-min) {
  //     margin-top: 3.3rem;
  //   }
  //   @media ($mobile-max) {
  //     margin-top: 2.85rem;
  //   }
  // }
  // & + %main-banner,
  // & + %filler {
  //   margin-top: 0;
  // }
  // & + %breadcrumbs {
  //   margin-top: 30px;
  // }
  &__callback-wrapper {
    width: 100%;
    min-width: 186px;

    @media ($header-min) {
      text-align: right;
    }
    @media ($header-max) {
      text-align: center;
    }
  }
  &__callback {
    &%_btn-transparent {
      --fz: 16px;
      --bdc: rgba(255,255,255,0.5);
      backdrop-filter: blur(30px);

      @media ($transition-min) {
        &:hover {
          z-index: 1;
          --bdc: var(--white);
        }
      }
    }

    @media ($header-max) {
      %header-mobile & {
        --p: 0;
      }

      &:before {
        top: -0.65em;
        left: -0.65em;
        right: -0.65em;
        bottom: -0.65em;
        content: "";
        display: block;
        position: absolute;
      }
      svg {
        width: 17px;
        height: 17px;
        margin-right: 0;
      }
    }
    @media ($mobile-max) {
      width: 100%;
    }
  }
  // @media ($header-max) {
  //   %feature-buttons {
  //     margin-top: 30px;
  //     margin-bottom: 30px;
  //   }
  // }
