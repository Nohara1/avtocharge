<!DOCTYPE html>
<html lang="ru">

@@include('./src/html/page/head.html', {
  title: "Виза для белорусов 2025 Запись в визовый центр более 50 стран",
  sliderPreload: false
})

<body>
  <div class="wrapper">
    @@include('./src/html/page/header.html', {
      transparent: false
    })

    @@include('./src/html/components/breadcrumbs.html', {
      elements: [
        { name: 'Главная', link: '/' },
        { name: 'Блог', link: '/blog' },
        { name: 'Авторы', link: '/blog-authors' },
        { name: 'Сигейкина Екатерина', link: '' }
      ]
    })

    @@include('./src/html/blocks/two-components.html', {
      extraClass: 'tc_author tc_proportions-rev _heading-wave',
      heading: 'Сигейкина Екатерина',
      hStyle: 2,
      hLevel: 1,
      subheading: '',
      title01: '',
      component01url: './src/html/components/image.html',
      component01params: '{ src: "images/team/sigejkina-ekaterina.jpg", thumb: "images/team/sigejkina-ekaterina.jpg", alt: "Сигейкина Екатерина", width: "500", height: "500", class: "image_author", responsive: false, gallery: "author" }',
      title02: '',
      component02url: './src/html/components/author.html',
      component02params: '{}',
    })

    @@include('./src/html/blocks/inner-items.html', {
      extraClass: 'ii_blog _heading-wave',
      heading: 'Посты автора',
      hLevel: '3',
      hStyle: '2',
      tabs: '',
      tabsActive: true,
      tabsSlider: false,
      text: '',
      columns: '4',
      columnsMobile: '',
      itemPath: './src/html/components/blog-item.html',
      jsonPath: '"../json/blog-4-elems.json"',
      pagination: ''
    })

    @@include('./src/html/page/footer.html')
  </div>
  @@include("./src/html/page/body-bottom.html")
</body>

</html>