<!DOCTYPE html>
<html lang="ru">

@@include('./src/html/page/head.html', {
  title: "Виза для белорусов 2025 Запись в визовый центр более 50 стран",
  sliderPreload: false
})

<body>
  <div class="wrapper">
    @@include('./src/html/page/header.html', {
      transparent: false
    })

    @@include('./src/html/blocks/banner.html', {
      extraClass: 'b_no-gap',
      slideClass: 'b__slide_blackout',
      image: 'images/banners/visa_spain.jpg',
      heading: 'Получение визы в Испанию',
      text: '<p>Наш специалист по визам разберет ваш случай и составит индивидуальный перечень документов</p>',
      achievements: '[{ icon: "check", title: "> 97%", text: "одобрения на получение визы" },{ icon: "ya", title: "5.0", text: "рейтинг Яндекса" },{ icon: "exp", title: "> 10 лет", text: "опыт наших специалистов" },{ icon: "review", title: "> 100 000", text: "довольных клиентов" }]',
      component: './src/html/forms/request-a-call.html'
    })

    @@include('./src/html/components/breadcrumbs.html', {
      elements: [
        { name: 'Главная', link: '/' },
        { name: 'Услуги', link: '/services' },
        { name: 'Получение визы в Испанию', link: '' }
      ]
    })

    @@include('./src/html/blocks/country-params.html', {
      items: './src/html/include/country-params-country.html'
    })

    @@include('./src/html/blocks/inner-items.html', {
      extraClass: '',
      heading: 'Мы открываем следующие типы виз в Испанию',
      subheading: '',
      text: '',
      columns: '',
      columnsMobile: '',
      subcategoriesTitle: '',
      subcategoriesJson: '',
      itemPath: './src/html/components/inner-items/card-visa.html',
      jsonPath: '"../json/inner-items-card-visa.json"'
    })

    @@include('./src/html/blocks/how-we-work.html', {
      heading: 'Как мы работаем'
    })

    @@include('./src/html/blocks/inner-items.html', {
      extraClass: 'ii_docs _plane',
      heading: 'Документы для оформления визы',
      subheading: '',
      text: '',
      columns: 4,
      columnsMobile: '',
      subcategoriesTitle: '',
      subcategoriesJson: '',
      itemPath: './src/html/components/inner-items/docs.html',
      jsonPath: '[{ title: "Для всех типов виз", popup: "docs" },{ title: "Туристическая виза", popup: "docs" },{ title: "Гостевая виза", popup: "docs" },{ title: "Бизнес виза", popup: "docs" },{ title: "Студенческая виза", popup: "docs" },{ title: "Рабочая виза", popup: "docs" },{ title: "Деловая виза", popup: "docs" }]'
    })

    @@include('./src/html/blocks/inner-items.html', {
      extraClass: 'ii_why-us _heading-wave',
      heading: 'Почему стоит выбрать нас',
      subheading: '',
      text: '',
      columns: 5,
      columnsMobile: '',
      subcategoriesTitle: '',
      subcategoriesJson: '',
      itemPath: './src/html/components/inner-items/inner-items-item.html',
      jsonPath: '"../json/inner-items-why-us.json"'
    })

    @@include('./src/html/blocks/custom-slider.html', {
      extraClass: '',
      gap: 40,
      slides: 'auto',
      mobSlides: 'auto',
      filter: false,
      heading: 'Сопутствующие услуги',
      text: '',
