<!DOCTYPE html>
<html lang="ru">
@@include('./src/html/page/head.html', {
  title: "Вакансии"
})

<body>
  <div class="wrapper">
    @@include('./src/html/page/header.html')

    @@include('./src/html/components/breadcrumbs.html', {
      elements: [
        { name: 'Главная', link: '/' },
        { name: 'О компании', link: '/o-kompanii' },
        { name: 'Вакансии', link: '' }
      ]
    })

    @@include('./src/html/blocks/inner-items.html', {
      extraClass: 'ii_vacancies ii_grow',
      heading: 'Почему работать с нами—круто?',
      text: '',
      columns: '',
      columnsMobile: 1,
      subcategoriesTitle: '',
      subcategoriesJson: '',
      itemPath: './src/html/components/inner-items/inner-items-item.html',
      jsonPath: '[{ title: "Комфортные условия работы", text: "<p>Дружеская атмосфера, комфортное рабочее место, хорошая техника - важные вещи, от которых напрямую зависит продуктивность. И мы это учитываем.</p>" },{ title: "Обучение сотрудников", text: "<p>Компания заинтересована в том, чтобы сотрудники регулярно повышали уровень знаний и навыков. Поэтому мы помогаем своим сотрудникам проходить курсы повышения квалификации.</p>" },{ title: "Компания растет вместе с вами", text: "<p>Мы понимаем, что благодаря росту компетенций, мы можем обслуживать более сложные и дорогие проекты. Это отражается на заработной плате всех сотрудников, которая регулярно пересматривается в зависимости от результатов работы.</p>" },{ title: "Работа на результат", text: "<p>Наша главная ценность - это делать хорошее SEO, создавать красивые и удобные сайты и качественно настраивать рекламу. Мы не приветствуем халявы и работы напоказ. Мы делаем работу на совесть и ищем в команду людей, которые готовы разделить с нами эту философию.</p>" },{ title: "Возможность для роста", text: "<p>Мы открыты для новых идей и предложений. Если вы хотите освоить смежную специальность в рамках наших компетенций, то мы вам поможем.<br>В нашей команде из контент-менеджеров вырастают проджекты, дизайнеры и SEO-специалисты. Все возможно!</p>" }]'
    })

    @@include('./src/html/blocks/vacancies.html', {
      heading: 'Актуальные вакансии CWEB',
      hLevel: 1,
      hStyle: 2,
      vacancies: [
        { title: 'Контент-менеджер', class: '', href: '/vacancy-entry', tag: 'Вакансия открыта', text: '<p>Рисуешь эффектный и трендовый дизайн<br>Понимаешь что такое UI/UX<br>Думаешь о пользователях<br>Учитываешь особенности вёрстки и CMS<br>Можешь собрать баннер и поп-ап<br>Работаешь в Figma</p>' },
        { title: 'SEO Junior', class: '', href: '/vacancy-entry', tag: 'Вакансия открыта', text: '<p>Рисуешь эффектный и трендовый дизайн<br>Понимаешь что такое UI/UX<br>Думаешь о пользователях<br>Учитываешь особенности вёрстки и CMS<br>Можешь собрать баннер и поп-ап<br>Работаешь в Figma</p>' },
        { title: 'Project-менеджер/Аккаунт-менеджер', class: '', href: '/vacancy-entry', tag: 'Вакансия открыта', text: '<p>Рисуешь эффектный и трендовый дизайн<br>Понимаешь что такое UI/UX<br>Думаешь о пользователях<br>Учитываешь особенности вёрстки и CMS<br>Можешь собрать баннер и поп-ап<br>Работаешь в Figma</p>' },
        { title: 'Web/UI/UX дизайнер', class: 'vacs__item_closed', href: '/vacancy-entry', tag: 'Вакансия закрыта', text: '<p>Рисуешь эффектный и трендовый дизайн<br>Понимаешь что такое UI/UX<br>Думаешь о пользователях<br>Учитываешь особенности вёрстки и CMS<br>Можешь собрать баннер и поп-ап<br>Работаешь в Figma</p>' },
        { title: 'PPC-специалист', class: 'vacs__item_closed', href: '/vacancy-entry', tag: 'Вакансия закрыта', text: '<p>Рисуешь эффектный и трендовый дизайн<br>Понимаешь что такое UI/UX<br>Думаешь о пользователях<br>Учитываешь особенности вёрстки и CMS<br>Можешь собрать баннер и поп-ап<br>Работаешь в Figma</p>' },
        { title: 'Front-end/Верстальщик', class: 'vacs__item_closed', href: '/vacancy-entry', tag: 'Вакансия закрыта', text: '<p>Рисуешь эффектный и трендовый дизайн<br>Понимаешь что такое UI/UX<br>Думаешь о пользователях<br>Учитываешь особенности вёрстки и CMS<br>Можешь собрать баннер и поп-ап<br>Работаешь в Figma</p>' },
        { title: 'Менеджер по продажам', class: 'vacs__item_closed', href: '/vacancy-entry', tag: 'Вакансия закрыта', text: '<p>Рисуешь эффектный и трендовый дизайн<br>Понимаешь что такое UI/UX<br>Думаешь о пользователях<br>Учитываешь особенности вёрстки и CMS<br>Можешь собрать баннер и поп-ап<br>Работаешь в Figma</p>' },
        { title: 'Офис-менеджер', class: 'vacs__item_closed', href: '/vacancy-entry', tag: 'Вакансия закрыта', text: '<p>Рисуешь эффектный и трендовый дизайн<br>Понимаешь что такое UI/UX<br>Думаешь о пользователях<br>Учитываешь особенности вёрстки и CMS<br>Можешь собрать баннер и поп-ап<br>Работаешь в Figma</p>' },
      ]
    })

    @@include('./src/html/blocks/form-with-links.html', {
