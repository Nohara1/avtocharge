<!DOCTYPE html>
<html lang="ru">

@@include('./src/html/page/head.html', {
  title: "Часто задаваемые вопросы"
})

<body>
  <div class="wrapper">
    @@include('./src/html/page/header.html')

    @@if(false){@@include('./src/html/components/breadcrumbs.html', {
      jsonPath: '../json/breadcrumbs/faq.json'
    })}

    @@include('./src/html/blocks/collapse.html', {
      h1: true,
      hStyle: 2,
      self: true,
      style: 1,
      heading: "Часто задаваемые вопросы",
      jsonPath: '../json/collapse-6-pieces.json'
    })

    @@include('./src/html/blocks/form-with-map.html')

    @@include('./src/html/page/footer.html')
  </div>
  @@include("./src/html/page/body-bottom.html", {
    checkout: false
  })
</body>

</html>