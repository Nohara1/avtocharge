<!DOCTYPE html>
<html lang="ru">

@@include('./src/html/page/head.html', {
  title: "Отзывы"
})

<body>
  <div class="wrapper">
    @@include('./src/html/page/header.html')

    @@include('./src/html/components/breadcrumbs.html', {
      elements: [
        { name: 'Главная', link: '/' },
        { name: 'О компании', link: '/o-kompanii' },
        { name: 'Отзывы', link: '' }
      ]
    })

    @@include('./src/html/blocks/heading.html', {
      heading: 'Отзывы',
      hLevel: 1,
      hStyle: 2,
      noGap: true
